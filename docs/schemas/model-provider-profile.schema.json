{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alkemist.dev/schemas/model-provider-profile.schema.json",
  "title": "Alkemist Model Provider Profile",
  "type": "object",
  "required": ["version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "active_profile_id": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "persona_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visionary": { "$ref": "#/$defs/personaDefault" },
        "engineer": { "$ref": "#/$defs/personaDefault" },
        "contractor": { "$ref": "#/$defs/personaDefault" },
        "finisher": { "$ref": "#/$defs/personaDefault" }
      }
    }
  },
  "$defs": {
    "providerType": {
      "type": "string",
      "enum": [
        "ollama",
        "anthropic",
        "xai",
        "openai_compatible",
        "custom"
      ]
    },
    "authType": {
      "type": "string",
      "enum": ["none", "api_key", "bearer_token", "custom_header"]
    },
    "personaDefault": {
      "type": "object",
      "required": ["profile_id", "model"],
      "additionalProperties": false,
      "properties": {
        "profile_id": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "profile": {
      "type": "object",
      "required": [
        "id",
        "name",
        "provider_type",
        "endpoint",
        "auth",
        "models",
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]{2,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "provider_type": {
          "$ref": "#/$defs/providerType"
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "auth": {
          "$ref": "#/$defs/auth"
        },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/modelEntry" },
          "minItems": 1
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "rate_limits": {
          "$ref": "#/$defs/rateLimits"
        },
        "enabled": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/authType" },
        "secret_ref": {
          "type": "string",
          "description": "Reference key in local secure store; never raw token in profile file"
        },
        "header_name": {
          "type": "string"
        },
        "prefix": {
          "type": "string",
          "default": "Bearer"
        }
      }
    },
    "modelEntry": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "context_window": { "type": "integer", "minimum": 1 },
        "supports_tools": { "type": "boolean" },
        "supports_reasoning": { "type": "boolean" },
        "supports_vision": { "type": "boolean" },
        "recommended_for": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["visionary", "engineer", "contractor", "finisher"]
          },
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chat": { "type": "boolean", "default": true },
        "streaming": { "type": "boolean", "default": true },
        "json_mode": { "type": "boolean", "default": false },
        "tool_calling": { "type": "boolean", "default": false },
        "reasoning_trace": { "type": "boolean", "default": false }
      }
    },
    "rateLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rpm": { "type": "integer", "minimum": 1 },
        "tpm": { "type": "integer", "minimum": 1 },
        "concurrency": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
